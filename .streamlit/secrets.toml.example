# Copy to .streamlit/secrets.toml (local) or paste into the Streamlit Cloud
# "Secrets" UI. Streamlit also exposes these as environment variables, so
# app/config.py picks them up via os.getenv().

GEMINI_API_KEY = "your-gemini-api-key"
GEMINI_MODEL = "gemini-2.5-flash"

# Database: ephemeral SQLite by default on Streamlit Cloud (resets on reboot).
# For persistence, point at a hosted MySQL:
# DATABASE_URL = "mysql+pymysql://user:password@host:3306/finverse"
DATABASE_URL = "sqlite:///finverse.db"

# Optional — only needed if you also run the alert engine
TELEGRAM_BOT_TOKEN = ""
TELEGRAM_CHAT_ID = ""
