# Backend API base URL (used directly by axios in production builds;
# in dev, /api is proxied to this target via vite.config.ts)
VITE_API_URL=http://localhost:8000/api

# Sentry error monitoring (optional). Set in the Vercel project env to enable;
# leave empty and Sentry stays fully disabled (no-op).
VITE_SENTRY_DSN=
