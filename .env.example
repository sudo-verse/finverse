# Finverse environment — copy to .env and fill in. NEVER commit the real .env.

# --- Database --------------------------------------------------------------
# Local dev defaults to SQLite (sqlite:///finverse.db). For Postgres/prod:
# DATABASE_URL=postgresql+psycopg://finverse:CHANGE_ME@db:5432/finverse
# (docker-compose sets DATABASE_URL per-service; POSTGRES_PASSWORD seeds the db)
POSTGRES_PASSWORD=change-me-strong

# --- Auth (required in prod) ----------------------------------------------
# Long random string — e.g. `python -c "import secrets;print(secrets.token_urlsafe(48))"`
BACKEND_JWT_SECRET=change-me-to-a-long-random-secret

# --- Gemini (AI: RAG, reports, sentiment news) -----------------------------
GEMINI_API_KEY=your-gemini-key
# Optional extra keys rotated through on quota (separate projects):
# GEMINI_API_KEY1=...
# GEMINI_API_KEY2=...

# --- Stripe billing --------------------------------------------------------
BACKEND_STRIPE_SECRET_KEY=sk_test_or_live_...
BACKEND_STRIPE_PUBLISHABLE_KEY=pk_test_or_live_...
# From your Stripe webhook endpoint (or `stripe listen`). REQUIRED in prod so
# webhooks are signature-verified.
BACKEND_STRIPE_WEBHOOK_SECRET=whsec_...

# --- URLs ------------------------------------------------------------------
# Frontend origin(s) allowed by CORS (comma-separated) and the base URL Stripe
# redirects back to after checkout.
BACKEND_CORS_ORIGINS=https://app.finverse.example
BACKEND_APP_BASE_URL=https://app.finverse.example

# --- Observability ---------------------------------------------------------
# Environment label (development | staging | production) — log + Sentry context.
BACKEND_ENVIRONMENT=production
# Error tracking (optional; leave empty to disable). Requires sentry-sdk.
BACKEND_SENTRY_DSN=

# --- Optional --------------------------------------------------------------
# Cross-encoder reranker (off by default; see app/config.py)
# RERANKER_ENABLED=false
# Telegram alert delivery (alerts also show in-app regardless)
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...
